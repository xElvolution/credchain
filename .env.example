# Arkiv — Braga testnet (single chain for all on-chain data)
# Faucet: https://braga.hoodi.arkiv.network/faucet/
ARKIV_PRIVATE_KEY=
ARKIV_RPC_URL=https://braga.hoodi.arkiv.network/rpc
NEXT_PUBLIC_ARKIV_RPC_URL=https://braga.hoodi.arkiv.network/rpc
ARKIV_EXPIRY_DAYS=365
NEXT_PUBLIC_ARKIV_EXPLORER=https://explorer.braga.hoodi.arkiv.network/entity/
NEXT_PUBLIC_BRAGA_TX_EXPLORER=https://explorer.braga.hoodi.arkiv.network/tx/

# Privy
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_AVATAR_BUCKET=avatars

# Supabase Postgres — Project Settings → Database → Connection string
DATABASE_URL="postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Session signing (any random string)
NEXTAUTH_SECRET=
